# Riani & Leo Agent — environment template
# Copy to .env and fill in. NEVER commit .env to git.

# === Anthropic (Writer Agent) ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
WRITER_MODEL=claude-sonnet-4-6
WRITER_MAX_TOKENS=4096

# === Slack ===
# Get from api.slack.com/apps -> your app
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx
SLACK_APP_TOKEN=xapp-xxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxx
# Channel id for the writer/pd workroom (use Slack -> "Copy link" -> the part after /archives/)
SLACK_WORKROOM_CHANNEL=C01ABCDEFG

# === YouTube ===
# Created via Google Cloud Console; downloaded as client_secret.json
YOUTUBE_CLIENT_SECRETS=./youtube/client_secret.json
YOUTUBE_TOKEN=./youtube/token.json
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_DEFAULT_PRIVACY=private

# === Paths ===
DB_PATH=./data/agent.db
ICLOUD_INBOX=/Users/ligi/Pictures/Photos\ Library.photoslibrary
ASSET_STAGING_DIR=./data/assets
LOGS_DIR=./data/logs

# === Schedule (KST) ===
TZ=Asia/Seoul
WRITER_RUN_HHMM=18:00
PUBLISH_HHMM=21:00

# === Operations ===
DRY_RUN=true
LOG_LEVEL=INFO
