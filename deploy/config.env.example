# deploy/config.env — VM deploy config (copy to /etc/rianileo/deploy.env on the VM).
# Sourced by pull_deploy.sh / smoke.sh / bootstrap.sh. NOT secrets (those live in
# /etc/rianileo/env, populated from Secret Manager). Safe to commit the .example.

# Service user + repo location on the VM
RIANILEO_USER=rianileo
APP_DIR=/home/rianileo/rianileo-agent
SMOKE_DIR=/home/rianileo/rianileo-smoke      # isolated clone: smoke runs here, never on live
PY=/home/rianileo/rianileo-agent/.venv/bin/python

# Deploy source of truth
DEPLOY_REMOTE=origin
DEPLOY_BRANCH=main

# Where app secrets (SLACK_BOT_TOKEN, GOOGLE_API_KEY, GCS_ASSET_BUCKET, …) are sourced
APP_ENV_FILE=/etc/rianileo/env

# Slack webhook/channel for deploy notifications (optional; blank = log only)
DEPLOY_SLACK_NOTIFY=1

# NOTE: BOARD_EXEC_MODE (autonomous board executor on/off) is NOT set here — it lives in
# crontab.vm (the picker is a cron job) so there's ONE source of truth. Putting it here too
# would let deploy.env override the crontab and defeat the crontab kill switch.
