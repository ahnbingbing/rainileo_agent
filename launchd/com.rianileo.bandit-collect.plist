<?xml version="1.0" encoding="UTF-8"?>
<!--
  av-vs-rf bandit — daily 48h metrics collection (PD 2026-06-07).

  Pulls each uploaded episode's settled ~48h performance into video_performance.
  Runs daily at 06:30 KST (after icloud-sync at 06:00). Re-stats videos younger
  than BANDIT_RESTAT_DAYS, skips settled ones.

  Install:
      cp launchd/com.rianileo.bandit-collect.plist ~/Library/LaunchAgents/
      launchctl unload ~/Library/LaunchAgents/com.rianileo.bandit-collect.plist 2>/dev/null
      launchctl load   ~/Library/LaunchAgents/com.rianileo.bandit-collect.plist

  Replace 'ahnbingbing' with your macOS username if different (whoami).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key><string>com.rianileo.bandit-collect</string>

    <key>ProgramArguments</key>
    <array>
      <string>/Users/ahnbingbing/code/rianileo-agent/.venv/bin/python</string>
      <string>-m</string>
      <string>agents.bandit</string>
      <string>--collect</string>
    </array>

    <key>WorkingDirectory</key><string>/Users/ahnbingbing/code/rianileo-agent</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>TZ</key><string>Asia/Seoul</string>
      <key>PATH</key><string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
      <key>LOG_LEVEL</key><string>INFO</string>
    </dict>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key><integer>6</integer>
      <key>Minute</key><integer>30</integer>
    </dict>

    <key>StandardOutPath</key><string>/Users/ahnbingbing/code/rianileo-agent/data/logs/bandit.out.log</string>
    <key>StandardErrorPath</key><string>/Users/ahnbingbing/code/rianileo-agent/data/logs/bandit.err.log</string>

    <key>RunAtLoad</key><false/>
    <key>ProcessType</key><string>Background</string>
    <key>Nice</key><integer>10</integer>
  </dict>
</plist>
