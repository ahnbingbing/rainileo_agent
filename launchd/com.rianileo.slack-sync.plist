<?xml version="1.0" encoding="UTF-8"?>
<!--
  Slack media/channel backfill — every 15 min.
  Complements the live Slack listener (file_shared events): catches anything
  uploaded while the listener was down. VLM tagging of new assets is handled by
  the daily iCloud sync's --vlm pass (tag_assets_vlm runs on all untagged).

  Install:
    cp launchd/com.rianileo.slack-sync.plist ~/Library/LaunchAgents/
    launchctl unload ~/Library/LaunchAgents/com.rianileo.slack-sync.plist 2>/dev/null
    launchctl load   ~/Library/LaunchAgents/com.rianileo.slack-sync.plist
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key><string>com.rianileo.slack-sync</string>
    <key>ProgramArguments</key>
    <array>
      <string>/Users/ahnbingbing/code/rianileo-agent/.venv/bin/python</string>
      <string>scripts/slack_sync.py</string>
    </array>
    <key>WorkingDirectory</key><string>/Users/ahnbingbing/code/rianileo-agent</string>
    <key>EnvironmentVariables</key>
    <dict>
      <key>TZ</key><string>Asia/Seoul</string>
      <key>PATH</key><string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
      <key>LOG_LEVEL</key><string>INFO</string>
    </dict>
    <key>StartInterval</key><integer>900</integer>
    <key>StandardOutPath</key><string>/Users/ahnbingbing/code/rianileo-agent/data/logs/slack_sync.out.log</string>
    <key>StandardErrorPath</key><string>/Users/ahnbingbing/code/rianileo-agent/data/logs/slack_sync.err.log</string>
    <key>RunAtLoad</key><true/>
    <key>ProcessType</key><string>Background</string>
    <key>Nice</key><integer>10</integer>
  </dict>
</plist>
