<?xml version="1.0" encoding="UTF-8"?>
<!--
  YouTube published-videos cache refresh (PD 2026-06-14).

  Keeps `youtube_published_videos` (the Macro Reviewer's freshness basis = what's
  actually PUBLIC on YouTube) current. Runs every 30 min so a scheduled episode that
  flips public at its slot time, or a vetoed/deleted video, is reflected within ~30
  min — without every review hitting the API. (Reviews otherwise refresh lazily on a
  6h TTL; this job is the proactive update for public-transitions + vetoes.)

  Install:
      cp launchd/com.rianileo.ytcache.plist ~/Library/LaunchAgents/
      launchctl unload ~/Library/LaunchAgents/com.rianileo.ytcache.plist 2>/dev/null
      launchctl load   ~/Library/LaunchAgents/com.rianileo.ytcache.plist

  Replace 'ahnbingbing' with your macOS username if different (whoami).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key><string>com.rianileo.ytcache</string>

    <key>ProgramArguments</key>
    <array>
      <string>/Users/ahnbingbing/code/rianileo-agent/.venv/bin/python</string>
      <string>-m</string>
      <string>agents.reviewer_macro</string>
      <string>--sync-cache</string>
    </array>

    <key>WorkingDirectory</key><string>/Users/ahnbingbing/code/rianileo-agent</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>TZ</key><string>Asia/Seoul</string>
      <key>PATH</key><string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
      <key>LOG_LEVEL</key><string>INFO</string>
    </dict>

    <key>StartInterval</key><integer>1800</integer>

    <key>RunAtLoad</key><true/>

    <key>StandardOutPath</key><string>/Users/ahnbingbing/code/rianileo-agent/data/logs/ytcache.log</string>
    <key>StandardErrorPath</key><string>/Users/ahnbingbing/code/rianileo-agent/data/logs/ytcache.log</string>
  </dict>
</plist>
