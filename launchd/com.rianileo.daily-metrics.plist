<?xml version="1.0" encoding="UTF-8"?>
<!--
  DAILY per-video metrics digest (PD 2026-06-11: "지표는 매일 확인했으면").

  Every day 09:00 KST: pull fresh 48h metrics, then post a per-video digest
  (slot/lane/views/retention per episode, last 4 days + lane leader) to the
  workroom. This is SEPARATE from the WEEKLY strategy posteriors
  (com.rianileo.bandit-report, Mon 10:00) — the daily one is the glanceable
  "어제 올린 영상들 지표" board.

  Install:
      cp launchd/com.rianileo.daily-metrics.plist ~/Library/LaunchAgents/
      launchctl unload ~/Library/LaunchAgents/com.rianileo.daily-metrics.plist 2>/dev/null
      launchctl load   ~/Library/LaunchAgents/com.rianileo.daily-metrics.plist
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key><string>com.rianileo.daily-metrics</string>

    <key>ProgramArguments</key>
    <array>
      <string>/Users/ahnbingbing/code/rianileo-agent/.venv/bin/python</string>
      <string>-m</string>
      <string>agents.bandit</string>
      <string>--collect</string>
      <string>--daily</string>
      <string>--slack</string>
    </array>

    <key>WorkingDirectory</key><string>/Users/ahnbingbing/code/rianileo-agent</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>TZ</key><string>Asia/Seoul</string>
      <key>PATH</key><string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
      <key>LOG_LEVEL</key><string>INFO</string>
    </dict>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key><integer>9</integer>
      <key>Minute</key><integer>0</integer>
    </dict>

    <key>StandardOutPath</key><string>/Users/ahnbingbing/code/rianileo-agent/data/logs/daily-metrics.out.log</string>
    <key>StandardErrorPath</key><string>/Users/ahnbingbing/code/rianileo-agent/data/logs/daily-metrics.err.log</string>

    <key>RunAtLoad</key><false/>
    <key>ProcessType</key><string>Background</string>
    <key>Nice</key><integer>10</integer>
  </dict>
</plist>
