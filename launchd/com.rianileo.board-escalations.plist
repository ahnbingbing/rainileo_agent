<?xml version="1.0" encoding="UTF-8"?>
<!--
  Autonomous pickup for rayleo_board CLI escalations (PD 2026-06-22).

  The board bot queues repo-level/ambiguous requests into board_escalations and tells
  PD "a CLI session will handle it". This job is that consumer: every 20 min it spawns
  a HEADLESS Claude Code in PLAN (read-only) mode to analyze each open escalation, posts
  the analysis to the rayleo_board channel, and marks it handled. PLAN mode = can read
  but cannot edit/commit, so it only ever produces analysis; real fixes stay human-gated.

  Install:
      cp launchd/com.rianileo.board-escalations.plist ~/Library/LaunchAgents/
      launchctl unload ~/Library/LaunchAgents/com.rianileo.board-escalations.plist 2>/dev/null
      launchctl load   ~/Library/LaunchAgents/com.rianileo.board-escalations.plist
  Disable (kill switch): set BOARD_PICKER_ENABLED=0 below + reload, or unload the job.
  Logs: data/logs/board_escalations.{out,err}.log
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key><string>com.rianileo.board-escalations</string>

    <key>ProgramArguments</key>
    <array>
      <string>/Users/ahnbingbing/code/rianileo-agent/.venv/bin/python</string>
      <string>-m</string>
      <string>scripts.process_board_escalations</string>
    </array>

    <key>WorkingDirectory</key><string>/Users/ahnbingbing/code/rianileo-agent</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>TZ</key><string>Asia/Seoul</string>
      <key>PATH</key><string>/Users/ahnbingbing/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
      <key>BOARD_PICKER_ENABLED</key><string>1</string>
      <key>LOG_LEVEL</key><string>INFO</string>
    </dict>

    <key>StartInterval</key><integer>1200</integer>

    <key>RunAtLoad</key><false/>

    <key>StandardOutPath</key><string>/Users/ahnbingbing/code/rianileo-agent/data/logs/board_escalations.out.log</string>
    <key>StandardErrorPath</key><string>/Users/ahnbingbing/code/rianileo-agent/data/logs/board_escalations.err.log</string>
  </dict>
</plist>
